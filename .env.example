# ============================================
# AI-Powered Competitive Exam Intelligence System
# Environment Configuration Template
# ============================================

# ----------------
# LLM Configuration (REQUIRED)
# ----------------
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------
# Database Configuration (REQUIRED)
# ----------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=ai_news_aggregator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Combined DATABASE_URL (update with your credentials)
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/ai_news_aggregator

# ----------------
# Email Configuration (Optional - for digest delivery)
# ----------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

EMAIL_FROM=Exam Intelligence <your_email@gmail.com>
EMAIL_TO=recipient@gmail.com

# ----------------
# Application Settings
# ----------------
ENV=development
LOG_LEVEL=INFO

# ----------------
# Optional: Custom Configuration
# ----------------
# Uncomment and modify as needed

# Custom YouTube channels (comma-separated channel IDs)
# YOUTUBE_CHANNELS=UCYRBFLkuZ8ZAfwz7ayGGvZQ,UCnvC2wLZOiKdFkM8Ml4EzQg

# Custom exam categories (comma-separated)
# EXAM_CATEGORIES=Polity,Economy,International Relations,Science & Tech

# Pipeline settings
# DEFAULT_HOURS_LOOKBACK=24
# DEFAULT_TOP_N_ARTICLES=10
# MAX_RETRIES=3
# REQUEST_TIMEOUT=30

# Performance settings
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10
# API_RATE_LIMIT_PER_MINUTE=60